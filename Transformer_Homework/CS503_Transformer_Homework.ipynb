    "    epoch_loss_val /= len(loader_val)\n",
    "    val_losses.append(epoch_loss_val)\n",
    "    \n",
    "    print(f'Train loss: {epoch_loss_train:.3f}, val loss: {epoch_loss_val:.3f}')"
   ]
